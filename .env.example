# ───────────────────────────────────────────────────────────
# Pepper&Carrot Reading Companion — LOCAL DEV template
#
# Copy to .env (gitignored) for a fully local stack:
# Docker Postgres, local ChromaDB, local image storage,
# and Ollama on localhost.
#
# For prod overrides (Neon, R2, Modal, etc.), see
# .env.production.example.
# ───────────────────────────────────────────────────────────

# === Database (Docker Postgres at localhost:5432) ===
POSTGRES_USER=peppercarrot
POSTGRES_PASSWORD=peppercarrot_dev
POSTGRES_DB=peppercarrot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === ChromaDB ===
# Embedded mode — points at a directory on disk
CHROMA_PERSIST_DIR=./data/chroma

# === Storage ===
STORAGE_BACKEND=local
LOCAL_IMAGE_DIR=./data/images
LOCAL_IMAGE_URL_PREFIX=http://localhost:8000/images

# === Model providers ===
# Vision: descriptions are sibling .json files written by the
# `ingest-from-images` Claude Code skill (see
# .claude/skills/ingest-from-images/SKILL.md). 'json' is the only
# supported value today.
VISION_PROVIDER=json

# Local Ollama daemon — `ollama serve` on the host.
OLLAMA_BASE_URL=http://localhost:11434

# Chat: 'ollama' or 'anthropic'
CHAT_PROVIDER=ollama
OLLAMA_CHAT_MODEL=qwen2.5:7b

# Embeddings: 'sentence-transformers' or 'ollama' or 'anthropic'
# IMPORTANT: EMBEDDING_MODEL is provider-specific:
#   - ollama:                bge-m3
#   - sentence-transformers: BAAI/bge-m3
# Flip both together when switching providers. Both produce 1024-dim vectors.
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3

# Anthropic (only if any provider above is set to 'anthropic')
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-7

# === Backend ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO

# === Frontend (Vite) ===
# Vite loads from frontend/.env, but documenting the local value here
# so the full local stack is described in one place.
VITE_API_BASE_URL=http://localhost:8000
